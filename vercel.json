{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "api/waitlist.py",
      "use": "@vercel/python"
    },
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/waitlist",
      "dest": "api/waitlist.py"
    },
    {
      "src": "/(ask|mock-interview|generate-script|last-minute|health)(.*)",
      "dest": "backend/main.py"
    },
    {
      "src": "/(submit-code|run-code)(.*)",
      "dest": "backend/main.py"
    },
    {
      "src": "/",
      "dest": "frontend/index.html"
    },
    {
      "src": "/(.*)/",
      "dest": "frontend/$1/index.html"
    },
    {
      "src": "/(.*)\\.html$",
      "dest": "frontend/$1.html"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1.html"
    }
  ]
}
